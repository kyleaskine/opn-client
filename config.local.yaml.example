# The easiest way to create config.local.yaml is to run the setup wizard:
#     python3 setup.py
# Otherwise, copy this file to config.local.yaml and fill in your values.
# config.local.yaml is gitignored.

opn:
  endpoint: "https://your-opn-host.example.com"
  submitter_handle: "your-handle"

# Per-user API key generated from opn-tracker's /profile page.
# Sign in via OAuth, go to /profile, create a labeled key, and paste it here.
# Keys start with "opn_". Treat like a password; shown only once at creation.
api_key: "opn_PASTE_YOUR_KEY_HERE"

# YAFU install directory (required). YAFU writes nfs.dat, factor.log, etc.
# directly into cwd, so the worker always runs YAFU from this directory.
yafu:
  dir: "/home/youruser/yafu"
  # Optional overrides (defaults from config.yaml):
  # binary: "./yafu"
  # threads: 8
